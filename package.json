{
  "name": "@jimmyzhang95/codexteam",
  "version": "0.1.0",
  "description": "User-scoped Codex agent-team installer, CLI, and MCP runtime for lead-managed teammate orchestration.",
  "type": "module",
  "bin": "dist/src/cli.js",
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "demo:calculator": "tsx scripts/calculator-demo.ts",
    "demo:todo-cycle": "tsx scripts/todo-cycle-demo.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "codex",
    "plugin",
    "mcp",
    "agents",
    "orchestration"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
